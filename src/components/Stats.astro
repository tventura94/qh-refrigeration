---
const stats = [
  { figure: "24/7", label: "Emergency dispatch", note: "Walk in down at 2am? We pick up." },
  { figure: "15", suffix: "yrs", label: "In the Carolinas", note: "Same crew since 2011." },
  { figure: "450", suffix: "+", label: "Reviews", note: "4.9 stars on Google." },
  { figure: "NC", label: "Licensed & insured", note: "State HVAC license No. 31402." },
];
---

<section id="about" class="relative bg-[var(--color-ink)] text-[var(--color-paper)]">
  <div class="max-w-[1400px] mx-auto px-5 sm:px-8 py-20 lg:py-28">
    <div class="grid lg:grid-cols-[1fr_2fr] gap-10 items-end">
      <div>
        <p class="font-mono text-[10px] uppercase tracking-[0.32em] text-[var(--color-ember-light)]">
          ◇ Section B · By the numbers
        </p>
        <h2 class="mt-4 font-display text-[clamp(2.2rem,5vw,4.5rem)] leading-[0.95]" style="font-variation-settings: 'opsz' 144, 'wght' 700">
          What we've<br />
          <span class="italic font-light text-[var(--color-arctic-light)]" style="font-variation-settings: 'opsz' 144, 'wght' 300">stacked up.</span>
        </h2>
      </div>
      <p class="font-display text-lg lg:text-xl leading-relaxed text-[var(--color-paper)]/80 max-w-xl lg:justify-self-end" style="font-variation-settings: 'opsz' 36, 'wght' 400">
        We are a small bench of technicians who would rather earn the next
        job than chase a sale. The numbers below are the receipts.
      </p>
    </div>

    <div class="mt-14 grid grid-cols-2 lg:grid-cols-4 gap-px bg-[var(--color-paper)]/15 border border-[var(--color-paper)]/15">
      {stats.map((stat) => (
        <div class="bg-[var(--color-ink)] p-7 lg:p-9">
          <div class="flex items-baseline gap-1">
            <span class="font-display text-6xl lg:text-7xl font-bold tabular-nums text-[var(--color-paper)]" style="font-variation-settings: 'opsz' 144, 'wght' 900">
              {stat.figure}
            </span>
            {stat.suffix && (
              <span class="font-display text-2xl text-[var(--color-ember-light)]" style="font-variation-settings: 'opsz' 36, 'wght' 500">
                {stat.suffix}
              </span>
            )}
          </div>
          <div class="mt-5 rule pt-3" style="border-color: rgba(241,236,224,0.18)">
            <div class="font-mono text-[10px] uppercase tracking-[0.28em] text-[var(--color-ember-light)]">
              {stat.label}
            </div>
            <p class="mt-2 text-sm text-[var(--color-paper)]/70 leading-relaxed">
              {stat.note}
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
