---
interface Props {
  kicker?: string;
  title: string;
  lead?: string;
  align?: "center" | "left";
  tone?: "light" | "dark";
}

const {
  kicker,
  title,
  lead,
  align = "center",
  tone = "light",
} = Astro.props;

const alignment = align === "center" ? "text-center mx-auto" : "text-left";
const titleColor = tone === "dark" ? "text-white" : "text-[var(--color-navy)]";
const leadColor = tone === "dark" ? "text-slate-300" : "text-slate-600";
const kickerColor =
  tone === "dark"
    ? "bg-white/10 text-[var(--color-mint)] border-white/20"
    : "bg-[var(--color-accent)]/10 text-[var(--color-accent)] border-[var(--color-accent)]/20";
---

<div class={`${alignment} max-w-3xl`}>
  {
    kicker && (
      <span
        class={`inline-block px-3 py-1 mb-4 rounded-full text-xs font-semibold uppercase tracking-wider border ${kickerColor}`}
      >
        {kicker}
      </span>
    )
  }
  <h2
    class={`text-3xl md:text-4xl lg:text-[2.6rem] font-extrabold leading-tight ${titleColor}`}
  >
    {title}
  </h2>
  {
    lead && (
      <p class={`mt-4 text-base md:text-lg leading-relaxed ${leadColor}`}>
        {lead}
      </p>
    )
  }
</div>
