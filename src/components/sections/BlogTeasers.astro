---
import SectionHeading from "../ui/SectionHeading.astro";

const posts = [
  {
    category: "Heating",
    date: "Oct 14, 2026",
    title: "How to prep your furnace for an Anchorage winter",
    excerpt:
      "A simple checklist you can run through every fall to keep your furnace safe, efficient, and ready for the cold.",
    image:
      "https://images.unsplash.com/photo-1521783988139-89397d761dce?auto=format&fit=crop&w=800&q=80",
  },
  {
    category: "Efficiency",
    date: "Sep 28, 2026",
    title: "Cold climate heat pumps: are they worth it in Alaska?",
    excerpt:
      "Modern heat pumps work in Anchorage winters. Here is how the math actually shakes out for a typical home.",
    image:
      "https://images.unsplash.com/photo-1763562618419-d08a20e5faf8?auto=format&fit=crop&w=800&q=80",
  },
  {
    category: "Indoor Air",
    date: "Sep 12, 2026",
    title: "Five quick wins for cleaner indoor air this season",
    excerpt:
      "From filter upgrades to humidity control, small changes that make a big difference when you are stuck inside.",
    image:
      "https://images.unsplash.com/photo-1582719478250-c89cae4dc85b?auto=format&fit=crop&w=800&q=80",
  },
];
---

<section id="blog" class="bg-slate-50 py-16 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-center">
      <SectionHeading
        kicker="HVAC Tips & Guides"
        title="Helpful reads from the North Peak team"
        lead="Practical advice for Alaska homeowners. Written by techs, not marketers."
      />
    </div>

    <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        posts.map((post) => (
          <article class="group bg-white rounded-2xl overflow-hidden border border-slate-200 hover:shadow-xl transition-all">
            <div class="relative h-52 overflow-hidden">
              <img
                src={post.image}
                alt={post.title}
                class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-500"
              />
              <span class="absolute top-4 left-4 bg-[var(--color-accent)] text-white text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full">
                {post.category}
              </span>
            </div>
            <div class="p-6">
              <div class="text-xs text-slate-500 font-medium">{post.date}</div>
              <h3 class="mt-2 text-lg font-bold text-[var(--color-navy)] leading-snug group-hover:text-[var(--color-accent)] transition-colors">
                {post.title}
              </h3>
              <p class="mt-3 text-sm text-slate-600 leading-relaxed">
                {post.excerpt}
              </p>
              <a
                href="#"
                class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-[var(--color-accent)] hover:gap-2.5 transition-all"
              >
                Read article
                <svg
                  class="w-4 h-4"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M17 8l4 4m0 0l-4 4m4-4H3"
                  />
                </svg>
              </a>
            </div>
          </article>
        ))
      }
    </div>
  </div>
</section>
