---
import Button from "../ui/Button.astro";
---

<section id="contact" class="bg-[var(--color-mint)] py-12 lg:py-16">
  <div
    class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid lg:grid-cols-3 gap-8 items-center"
  >
    <div class="lg:col-span-2">
      <span
        class="inline-block px-3 py-1 rounded-full text-xs font-semibold uppercase tracking-wider bg-[var(--color-navy)] text-white"
      >
        Ready to Get Started?
      </span>
      <h2
        class="mt-4 text-3xl md:text-4xl lg:text-[2.4rem] font-extrabold text-[var(--color-navy)] leading-tight"
      >
        Cool is just a phone call away.
      </h2>
      <p class="mt-3 text-slate-700 text-base md:text-lg max-w-2xl">
        Talk to a real person, get a fair quote, and get your business or home
        back to the way it should feel. We are standing by 24 hours a day.
      </p>
    </div>
    <div class="flex flex-col sm:flex-row lg:flex-col gap-3 lg:items-end">
      <Button href="tel:7045550142" variant="primary" size="lg">
        <svg
          class="w-4 h-4"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            d="M3 5a2 2 0 012-2h2.28a2 2 0 011.94 1.515l.7 2.8a2 2 0 01-.45 1.81L7.91 11.09a16 16 0 005 5l2.165-1.56a2 2 0 011.81-.45l2.8.7A2 2 0 0121 16.72V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
          ></path>
        </svg>
        Call (704) 555-0142
      </Button>
      <Button href="#contact" variant="secondary" size="lg">
        Schedule Online
      </Button>
    </div>
  </div>
</section>
