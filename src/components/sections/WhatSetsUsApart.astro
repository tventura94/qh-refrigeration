---
import SectionHeading from "../ui/SectionHeading.astro";

const features = [
  {
    title: "Trusted Local Team",
    body: "Charlotte neighbors serving Charlotte kitchens, shops, and homes, with deep experience in Carolina humidity and high temperature equipment loads.",
    icon: "M5 13l4 4L19 7",
  },
  {
    title: "24/7 Emergency Response",
    body: "When your walk in fails at three in the morning or the AC quits before brunch service, we answer the phone and get a tech rolling.",
    icon: "M13 10V3L4 14h7v7l9-11h-7z",
  },
  {
    title: "Upfront Honest Pricing",
    body: "Flat rate quotes before any work begins. No surprise add ons, no high pressure sales.",
    icon: "M12 8c-1.66 0-3 .9-3 2s1.34 2 3 2 3 .9 3 2-1.34 2-3 2m0-8v8m0 0v1m0-9V3",
  },
  {
    title: "Factory Trained Techs",
    body: "Our team is certified across all major brands of walk ins, ice machines, reach ins, condensers, heat pumps, and ductless systems.",
    icon: "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z",
  },
  {
    title: "Commercial Refrigeration Specialists",
    body: "Walk in coolers, freezers, ice machines, and prep tables, dialed in for Charlotte restaurants, breweries, and grocers.",
    icon: "M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707m12.728 0l-.707-.707M6.343 6.343l-.707-.707M16 12a4 4 0 11-8 0 4 4 0 018 0z",
  },
  {
    title: "Workmanship Guarantee",
    body: "Every install and repair is backed by a written guarantee. If something is not right, we make it right.",
    icon: "M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z",
  },
];
---

<section class="bg-white py-16 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-center">
      <SectionHeading
        kicker="What Sets Us Apart"
        title="Why Charlotte businesses and homeowners choose QH"
        lead="We mix old school craftsmanship with modern equipment knowledge so your refrigeration and cooling runs better, longer."
      />
    </div>

    <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {
        features.map((feature) => (
          <div class="group rounded-2xl border border-slate-200 p-7 hover:border-[var(--color-accent)]/40 hover:shadow-lg transition-all">
            <span class="w-14 h-14 rounded-full bg-[var(--color-navy)] text-white flex items-center justify-center group-hover:bg-[var(--color-accent)] transition-colors">
              <svg
                class="w-6 h-6"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                viewBox="0 0 24 24"
              >
                <path
                  stroke-linecap="round"
                  stroke-linejoin="round"
                  d={feature.icon}
                />
              </svg>
            </span>
            <h3 class="mt-5 text-lg font-bold text-[var(--color-navy)]">
              {feature.title}
            </h3>
            <p class="mt-2 text-sm text-slate-600 leading-relaxed">
              {feature.body}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</section>
