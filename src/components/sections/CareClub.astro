---
import Button from "../ui/Button.astro";

const benefits = [
  "Two precision tune ups every year",
  "Priority same day scheduling",
  "15% discount on all repairs and parts",
  "No overtime fees, ever",
  "Multi-year extended warranties",
  "Annual indoor air quality check",
];
---

<section
  class="relative bg-[var(--color-navy)] text-white overflow-hidden py-16 lg:py-24"
>
  <div
    class="absolute inset-0 bg-[radial-gradient(circle_at_bottom_left,rgba(207,230,232,0.15),transparent_55%)]"
  >
  </div>
  <div
    class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 grid lg:grid-cols-2 gap-12 items-center"
  >
    <div>
      <span
        class="inline-block px-3 py-1 rounded-full text-xs font-semibold uppercase tracking-wider bg-[var(--color-accent)] text-white"
      >
        Membership
      </span>
      <h2
        class="mt-4 text-3xl md:text-4xl lg:text-5xl font-extrabold leading-tight"
      >
        Join the North Peak Comfort Club
      </h2>
      <p class="mt-4 text-slate-300 text-lg leading-relaxed max-w-xl">
        For one low monthly rate, get scheduled tune ups, priority service, and
        exclusive member only savings on repairs and replacements. It is the
        easiest way to keep your home comfortable year round.
      </p>
      <div class="mt-7 flex flex-wrap gap-3">
        <Button href="#contact" variant="primary" size="lg">
          Become a Member
        </Button>
        <Button href="#services" variant="ghost" size="lg">
          Learn More
        </Button>
      </div>
    </div>

    <div class="relative">
      <div
        class="absolute -top-3 -right-3 bg-[var(--color-accent)] text-white text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-md shadow-lg z-10"
      >
        Most Popular
      </div>
      <div
        class="relative bg-white text-slate-900 rounded-2xl p-8 shadow-2xl ring-1 ring-black/5"
      >
        <div class="flex items-baseline gap-2">
          <span class="text-5xl font-extrabold text-[var(--color-navy)]">
            $19
          </span>
          <span class="text-slate-500 text-sm">/ month</span>
        </div>
        <p class="text-slate-500 text-sm mt-1">
          Cancel anytime. No long term contract.
        </p>
        <ul class="mt-6 space-y-3">
          {
            benefits.map((benefit) => (
              <li class="flex items-start gap-3">
                <span class="w-5 h-5 rounded-full bg-[var(--color-accent)]/10 text-[var(--color-accent)] flex items-center justify-center mt-0.5 shrink-0">
                  <svg
                    class="w-3 h-3"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="3"
                    viewBox="0 0 24 24"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      d="M5 13l4 4L19 7"
                    />
                  </svg>
                </span>
                <span class="text-sm text-slate-700">{benefit}</span>
              </li>
            ))
          }
        </ul>
        <a
          href="#contact"
          class="mt-7 block w-full text-center bg-[var(--color-navy)] hover:bg-[var(--color-navy-soft)] text-white font-semibold py-3 rounded-md transition-colors"
        >
          Sign Up Today
        </a>
      </div>
    </div>
  </div>
</section>
