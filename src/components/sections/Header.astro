---
import Button from "../ui/Button.astro";

const navItems = [
  { label: "Services", href: "#services" },
  { label: "Service Area", href: "#service-area" },
  { label: "About", href: "#about" },
  { label: "Blog", href: "#blog" },
  { label: "Contact", href: "#contact" },
];
---

<header class="bg-white border-b border-slate-200 sticky top-0 z-40">
  <div
    class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 py-3 flex items-center justify-between gap-4 flex-nowrap whitespace-nowrap"
  >
    <a href="#home" class="flex items-center shrink-0">
      <img
        src="/logo.png"
        alt="North Peak Heating & Cooling"
        class="h-12 md:h-14 w-auto"
      />
    </a>

    <nav class="hidden lg:flex items-center gap-6 shrink-0">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class="text-sm font-semibold text-slate-700 hover:text-[var(--color-accent)] transition-colors whitespace-nowrap"
          >
            {item.label}
          </a>
        ))
      }
    </nav>

    <div class="flex items-center gap-3 shrink-0">
      <a
        href="tel:9075550123"
        class="hidden 2xl:flex items-center gap-2 text-sm font-semibold text-[var(--color-navy)] pr-3 border-r border-slate-200 whitespace-nowrap"
      >
        <span
          class="w-9 h-9 rounded-full bg-[var(--color-accent)]/10 text-[var(--color-accent)] flex items-center justify-center shrink-0"
        >
          <svg
            class="w-4 h-4"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            viewBox="0 0 24 24"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M3 5a2 2 0 012-2h2.28a2 2 0 011.94 1.515l.7 2.8a2 2 0 01-.45 1.81L7.91 11.09a16 16 0 005 5l2.165-1.56a2 2 0 011.81-.45l2.8.7A2 2 0 0121 16.72V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"
            ></path>
          </svg>
        </span>
        <span class="leading-tight">
          <span class="block text-[10px] uppercase text-slate-500 tracking-wider">
            Call Anytime
          </span>
          <span class="block text-[var(--color-navy)]">(907) 555-0123</span>
        </span>
      </a>
      <Button href="tel:9075550123" variant="primary" size="md" class="whitespace-nowrap">
        Book Service Now
      </Button>
      <a
        href="#contact"
        class="hidden xl:inline-flex items-center justify-center px-5 py-2.5 text-sm rounded-md font-semibold uppercase tracking-wide bg-[var(--color-mint)] text-[var(--color-navy)] hover:bg-[var(--color-mint-dark)] border border-[var(--color-mint-dark)] transition-colors whitespace-nowrap"
      >
        Get Free Estimate
      </a>
    </div>
  </div>
</header>
