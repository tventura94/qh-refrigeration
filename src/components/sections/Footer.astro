---
const year = new Date().getFullYear();

const columns = [
  {
    heading: "Services",
    links: [
      { label: "Heating Repair", href: "#services" },
      { label: "AC & Heat Pumps", href: "#services" },
      { label: "Installation", href: "#services" },
      { label: "Emergency Service", href: "#services" },
      { label: "Maintenance Plans", href: "#services" },
    ],
  },
  {
    heading: "Company",
    links: [
      { label: "About Us", href: "#about" },
      { label: "Our Team", href: "#about" },
      { label: "Careers", href: "#about" },
      { label: "Blog", href: "#blog" },
      { label: "Reviews", href: "#about" },
    ],
  },
  {
    heading: "Service Area",
    links: [
      { label: "Anchorage", href: "#service-area" },
      { label: "Eagle River", href: "#service-area" },
      { label: "Chugiak", href: "#service-area" },
      { label: "Girdwood", href: "#service-area" },
      { label: "JBER", href: "#service-area" },
    ],
  },
  {
    heading: "Contact",
    links: [
      { label: "(907) 555-0123", href: "tel:9075550123" },
      { label: "hello@northpeakhvac.com", href: "mailto:hello@northpeakhvac.com" },
      { label: "Anchorage, AK 99501", href: "#contact" },
      { label: "Open 24/7", href: "#contact" },
    ],
  },
];
---

<footer class="bg-[var(--color-navy-dark)] text-slate-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid lg:grid-cols-5 gap-10">
      <div class="lg:col-span-2">
        <img
          src="/logo.png"
          alt="North Peak Heating & Cooling"
          class="h-16 w-auto bg-white rounded-md p-2"
        />
        <p class="mt-5 text-sm leading-relaxed max-w-md text-slate-400">
          North Peak Heating & Cooling is a locally owned HVAC company serving
          Anchorage and South Central Alaska with honest pricing, fast service,
          and craftsmanship that holds up to Alaska winters.
        </p>
        <div class="mt-5 flex items-center gap-3">
          {
            ["Facebook", "Instagram", "Google"].map((label) => (
              <a
                href="#"
                aria-label={label}
                class="w-9 h-9 rounded-full bg-white/5 hover:bg-[var(--color-accent)] text-slate-300 hover:text-white flex items-center justify-center transition-colors"
              >
                <span class="text-xs font-bold">{label.charAt(0)}</span>
              </a>
            ))
          }
        </div>
      </div>

      {
        columns.map((column) => (
          <div>
            <h4 class="text-white font-bold text-sm uppercase tracking-wider">
              {column.heading}
            </h4>
            <ul class="mt-4 space-y-2">
              {column.links.map((link) => (
                <li>
                  <a
                    href={link.href}
                    class="text-sm text-slate-400 hover:text-white transition-colors"
                  >
                    {link.label}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))
      }
    </div>
  </div>

  <div class="border-t border-white/10">
    <div
      class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-5 flex flex-col sm:flex-row items-center justify-between gap-3 text-xs text-slate-500"
    >
      <div>
        &copy; {year} North Peak Heating & Cooling. All rights reserved.
      </div>
      <div class="flex items-center gap-5">
        <a href="#" class="hover:text-white transition-colors">Privacy</a>
        <a href="#" class="hover:text-white transition-colors">Terms</a>
        <a href="#" class="hover:text-white transition-colors">Sitemap</a>
      </div>
    </div>
  </div>
</footer>
