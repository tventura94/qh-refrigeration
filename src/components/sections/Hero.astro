---
const heroImage =
  "https://images.unsplash.com/photo-1660330589827-da8ab7dd3c02?auto=format&fit=crop&w=1400&q=80";

const checks = [
  "$89 diagnostic fee, waived with any repair",
  "Same day service available, no overtime charges",
  "Locally owned, serving Charlotte businesses and homes year round",
];
---

<section
  id="home"
  class="relative bg-slate-50 overflow-hidden"
>
  <div
    class="absolute inset-0 bg-[radial-gradient(circle_at_top_right,rgba(207,230,232,0.4),transparent_55%)]"
  >
  </div>
  <div
    class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12 lg:py-20 grid lg:grid-cols-2 gap-12 items-center"
  >
    <div>
      <div class="flex flex-wrap items-center gap-3">
        <div
          class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-white border border-slate-200 shadow-sm text-xs font-semibold text-slate-700"
        >
          <span
            class="w-5 h-5 rounded-full bg-gradient-to-br from-blue-500 via-red-500 to-yellow-400 flex items-center justify-center text-white text-[10px] font-bold"
          >G</span>
          <span>4.9 Rating on Google</span>
          <span class="flex gap-0.5 text-yellow-400">
            {
              Array.from({ length: 5 }).map(() => (
                <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M10 1l2.6 5.3 5.9.9-4.2 4.1 1 5.8L10 14.8 4.7 17.1l1-5.8L1.5 7.2l5.9-.9z" />
                </svg>
              ))
            }
          </span>
        </div>
        <div
          class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full bg-amber-50 border border-amber-200 text-xs font-semibold text-amber-900"
        >
          <span class="text-base leading-none">★</span>
          <span>Family Owned & Operated</span>
        </div>
      </div>

      <h1
        class="mt-6 text-4xl md:text-5xl lg:text-6xl font-extrabold leading-[1.05] tracking-tight text-[var(--color-navy)]"
      >
        Charlotte Refrigeration Experts
      </h1>
      <h2
        class="mt-1 text-3xl md:text-4xl lg:text-5xl font-extrabold leading-[1.05] tracking-tight text-[var(--color-accent)]"
      >
        Commercial Cooling Done Right
      </h2>

      <p class="mt-5 text-base md:text-lg text-slate-600 max-w-xl leading-relaxed">
        Honest pricing. Expert service. No high pressure sales. Walk in coolers,
        ice machines, freezers, and home cooling from a local Charlotte team
        that treats you like neighbors.
      </p>

      <ul class="mt-6 space-y-2.5">
        {
          checks.map((item) => (
            <li class="flex items-start gap-2.5">
              <span class="w-5 h-5 rounded-full bg-emerald-100 text-emerald-600 flex items-center justify-center mt-0.5 shrink-0">
                <svg
                  class="w-3 h-3"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="3"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M5 13l4 4L19 7"
                  />
                </svg>
              </span>
              <span class="text-sm text-slate-700">{item}</span>
            </li>
          ))
        }
      </ul>

      <div class="mt-7 grid sm:grid-cols-2 gap-4 max-w-xl">
        <div
          class="bg-white rounded-xl border border-slate-200 p-5 shadow-sm"
        >
          <span
            class="inline-block px-2.5 py-1 rounded-md bg-emerald-100 text-emerald-700 text-[10px] font-bold uppercase tracking-wider"
          >
            Available Now
          </span>
          <p class="mt-3 text-sm font-bold text-[var(--color-navy)]">
            Need your system repaired today?
          </p>
          <a
            href="tel:7045550142"
            class="mt-3 block text-center bg-[var(--color-accent)] hover:bg-[#c9261d] text-white font-semibold text-sm uppercase tracking-wide py-2.5 rounded-md transition-colors"
          >
            Book Service Now
          </a>
        </div>
        <div
          class="bg-white rounded-xl border border-slate-200 p-5 shadow-sm"
        >
          <span
            class="inline-block px-2.5 py-1 rounded-md bg-[var(--color-navy)] text-white text-[10px] font-bold uppercase tracking-wider"
          >
            Online Estimate
          </span>
          <p class="mt-3 text-sm font-bold text-[var(--color-navy)]">
            Want a free estimate today?
          </p>
          <a
            href="#contact"
            class="mt-3 block text-center bg-[var(--color-mint)] hover:bg-[var(--color-mint-dark)] text-[var(--color-navy)] font-semibold text-sm uppercase tracking-wide py-2.5 rounded-md transition-colors"
          >
            Get Free Estimate
          </a>
        </div>
      </div>
    </div>

    <div class="relative">
      <div
        class="absolute -inset-4 bg-[var(--color-mint)]/40 blur-3xl rounded-full"
      >
      </div>
      <div
        class="relative rounded-2xl overflow-hidden ring-1 ring-slate-200 shadow-2xl"
      >
        <img
          src={heroImage}
          alt="HVAC technician servicing equipment"
          class="w-full h-[460px] object-cover"
        />
      </div>
      <div
        class="absolute -bottom-6 -left-6 bg-white text-[var(--color-navy)] rounded-xl px-5 py-4 shadow-xl hidden md:block"
      >
        <div class="flex items-center gap-3">
          <span
            class="w-10 h-10 rounded-full bg-[var(--color-accent)]/10 text-[var(--color-accent)] flex items-center justify-center"
          >
            <svg
              class="w-5 h-5"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path>
            </svg>
          </span>
          <div>
            <div class="text-xs text-slate-500 uppercase tracking-wider">
              Same-day service
            </div>
            <div class="text-sm font-semibold">
              Most repairs done in one visit
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
