---
import SectionHeading from "../ui/SectionHeading.astro";

const faqs = [
  {
    q: "How quickly can a technician get to my home?",
    a: "For most calls in the Anchorage area we offer same day service. For true no-heat emergencies in winter, we dispatch around the clock and aim to arrive within a couple of hours.",
  },
  {
    q: "Do you charge a service fee or trip charge?",
    a: "We charge a small diagnostic fee that covers a full system inspection. If you move forward with the recommended repair, that fee is applied directly to the work.",
  },
  {
    q: "Do you work on all brands of equipment?",
    a: "Yes. Our technicians are trained on all major HVAC brands. We can repair what you have today and recommend the best replacement options when the time comes.",
  },
  {
    q: "Are heat pumps a good option for Alaska homes?",
    a: "Cold climate heat pumps have come a long way and they work well in Anchorage when properly sized and installed. We can run the numbers for your home and walk you through the trade offs.",
  },
  {
    q: "Do you offer financing on new systems?",
    a: "Yes. We offer flexible monthly payment plans through our financing partners on qualifying installations. Approval typically takes just a few minutes.",
  },
  {
    q: "What kind of warranties do you provide?",
    a: "Manufacturer warranties cover the equipment and we back our installation labor with a multi-year workmanship guarantee. We will register everything for you.",
  },
];
---

<section class="bg-white py-16 lg:py-24">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-center">
      <SectionHeading
        kicker="FAQ"
        title="Common questions about HVAC service"
        lead="If you do not see your question below, give us a call. We are happy to answer."
      />
    </div>

    <div class="mt-10 divide-y divide-slate-200 border-y border-slate-200">
      {
        faqs.map((faq) => (
          <details class="group py-5">
            <summary class="flex items-center justify-between gap-4 cursor-pointer list-none">
              <span class="text-base md:text-lg font-semibold text-[var(--color-navy)]">
                {faq.q}
              </span>
              <span class="w-8 h-8 rounded-full bg-slate-100 text-[var(--color-navy)] flex items-center justify-center shrink-0 group-open:bg-[var(--color-accent)] group-open:text-white transition-colors">
                <svg
                  class="w-4 h-4 transition-transform group-open:rotate-45"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2.5"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M12 4v16m8-8H4"
                  />
                </svg>
              </span>
            </summary>
            <p class="mt-3 text-sm md:text-base text-slate-600 leading-relaxed pr-12">
              {faq.a}
            </p>
          </details>
        ))
      }
    </div>
  </div>
</section>
