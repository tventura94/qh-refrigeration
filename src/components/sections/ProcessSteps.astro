---
import SectionHeading from "../ui/SectionHeading.astro";

const repairProcess = [
  "You call QH. A real person picks up.",
  "We schedule a same day appointment when possible.",
  "Our tech arrives in a clearly marked truck on time.",
  "We diagnose the problem and explain it in plain English.",
  "You approve a flat rate quote before we start work.",
  "We finish the repair, clean up, and confirm everything is back at temperature.",
];

const replacementProcess = [
  "We perform a full site assessment and load calculation.",
  "You receive multiple equipment options at clear price points.",
  "We schedule the install around your business or family calendar.",
  "Our crew protects your floors and works around your operation.",
  "Old equipment is hauled away and refrigerant properly reclaimed.",
  "We register your warranty and walk you through the new system.",
];
---

<section class="bg-white py-16 lg:py-24">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-center">
      <SectionHeading
        kicker="Our Process"
        title="What to expect when you call QH"
        lead="No surprises, no high pressure pitches. Here is exactly how every job goes."
      />
    </div>

    <div class="mt-12 grid lg:grid-cols-2 gap-6">
      <div class="bg-slate-50 rounded-2xl p-8 border border-slate-200">
        <div class="flex items-center gap-3">
          <span
            class="w-11 h-11 rounded-lg bg-[var(--color-accent)] text-white flex items-center justify-center"
          >
            <svg
              class="w-5 h-5"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"
              ></path>
            </svg>
          </span>
          <h3 class="text-2xl font-extrabold text-[var(--color-navy)]">
            The Repair Process
          </h3>
        </div>
        <ol class="mt-6 space-y-4">
          {
            repairProcess.map((step, index) => (
              <li class="flex items-start gap-4">
                <span class="w-8 h-8 rounded-full bg-white border border-slate-200 text-[var(--color-navy)] font-bold text-sm flex items-center justify-center shrink-0">
                  {index + 1}
                </span>
                <span class="text-sm text-slate-700 leading-relaxed pt-1.5">
                  {step}
                </span>
              </li>
            ))
          }
        </ol>
      </div>

      <div class="bg-[var(--color-navy)] text-white rounded-2xl p-8">
        <div class="flex items-center gap-3">
          <span
            class="w-11 h-11 rounded-lg bg-[var(--color-mint)] text-[var(--color-navy)] flex items-center justify-center"
          >
            <svg
              class="w-5 h-5"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              viewBox="0 0 24 24"
            >
              <path
                stroke-linecap="round"
                stroke-linejoin="round"
                d="M3 7l9-4 9 4-9 4-9-4zm0 6l9 4 9-4M3 17l9 4 9-4"
              ></path>
            </svg>
          </span>
          <h3 class="text-2xl font-extrabold">The Replacement Process</h3>
        </div>
        <ol class="mt-6 space-y-4">
          {
            replacementProcess.map((step, index) => (
              <li class="flex items-start gap-4">
                <span class="w-8 h-8 rounded-full bg-white/10 border border-white/20 text-white font-bold text-sm flex items-center justify-center shrink-0">
                  {index + 1}
                </span>
                <span class="text-sm text-slate-200 leading-relaxed pt-1.5">
                  {step}
                </span>
              </li>
            ))
          }
        </ol>
      </div>
    </div>
  </div>
</section>
