---

const googleStars = Array.from({ length: 5 });

const reviews = [
  {
    tag: "Emergency Service",
    quote:
      "Called at 11pm when our heat quit in February. Someone was at the house by dawn and had us warm again before noon. Straightforward price, no scare tactics.",
    name: "Michael J.",
    location: "Bear Valley, Anchorage",
    featured: false,
    initials: "MJ",
    avatarHue: "from-slate-500 to-slate-700",
  },
  {
    tag: "AC Repair",
    quote:
      "Finally found an HVAC shop that doesn't push parts you don't need. The tech walked us through what was wrong, the quote matched the bill, and they have our business going forward.",
    name: "Sarah M.",
    location: "Turnagain, Anchorage",
    featured: true,
    initials: "SM",
    avatarHue: "from-rose-400 to-orange-400",
  },
  {
    tag: "AC Installation",
    quote:
      "Financing options made replacing our old AC possible without wiping out savings. Payment plan is manageable and the install crew was respectful of our rugs and pets.",
    name: "Lisa A.",
    location: "Muldoon, Anchorage",
    featured: false,
    initials: "LA",
    avatarHue: "from-violet-400 to-purple-600",
  },
  {
    tag: "Furnace Installation",
    quote:
      "Whole process felt organized. Crew showed up on time, taped off walkways, and the new furnace is whisper quiet. House feels warmer with the same thermostat setting.",
    name: "Jennifer D.",
    location: "Eagle River",
    featured: false,
    initials: "JD",
    avatarHue: "from-emerald-400 to-teal-600",
  },
  {
    tag: "Maintenance Plan",
    quote:
      "Five years with North Peak tuning both units. Reminders come before shoulder season and pricing has stayed fair. Recommend them anytime someone asks locally.",
    name: "Robert W.",
    location: "Hillside, Anchorage",
    featured: false,
    initials: "RW",
    avatarHue: "from-amber-500 to-orange-700",
  },
  {
    tag: "Heat Pump Service",
    quote:
      "We were nervous about cold climate heat pumps. They sized the load right, dialed in the defrost settings, and stayed until every room tracked even.",
    name: "Chen W.",
    location: "South Anchorage",
    featured: false,
    initials: "CW",
    avatarHue: "from-sky-400 to-blue-700",
  },
  {
    tag: "Duct Cleaning",
    quote:
      "Allergies were brutal after drywall work. Scheduling was easy and the tech showed before and after camera shots. Sleeping better since they left.",
    name: "Amy K.",
    location: "Sand Lake",
    featured: false,
    initials: "AK",
    avatarHue: "from-fuchsia-400 to-pink-600",
  },
  {
    tag: "Heating Repair",
    quote:
      "Boiler sounded like a tractor. Thought we'd need all new piping. Turns out one circulator pump and they're out the door same day.",
    name: "Marcus T.",
    location: "Downtown Anchorage",
    featured: false,
    initials: "MT",
    avatarHue: "from-slate-600 to-slate-900",
  },
  {
    tag: "AC Repair",
    quote:
      "Second floor was always roasting. Mini split add on was quoted clearly and wired neatly. Already planning the next zone through them.",
    name: "Elena V.",
    location: "Spenard",
    featured: false,
    initials: "EV",
    avatarHue: "from-red-400 to-rose-600",
  },
];
---

<section class="reviews-marble py-16 lg:py-24 relative overflow-hidden">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative z-[1]">
    <header class="text-center max-w-3xl mx-auto mb-12">
      <h2
        class="text-[var(--color-navy)] text-3xl md:text-4xl font-extrabold tracking-tight"
      >
        What Anchorage homeowners say about us
      </h2>
      <p class="mt-4 text-base text-slate-600 leading-relaxed">
        Do not take our word alone. Here is why 455+ households across Southcentral
        trust North Peak when the temperature swings.
      </p>
      <div
        class="mt-6 inline-flex items-center gap-2 flex-wrap justify-center whitespace-nowrap"
      >
        <svg
          class="w-5 h-5 shrink-0"
          viewBox="0 0 24 24"
          aria-hidden="true"
        >
          <path
            fill="#4285F4"
            d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
          ></path>
          <path
            fill="#34A853"
            d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
          ></path>
          <path
            fill="#FBBC05"
            d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
          ></path>
          <path
            fill="#EA4335"
            d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
          ></path>
        </svg>
        <span class="font-semibold text-[var(--color-navy)] text-sm sm:text-base"
          >4.9 Rating on Google</span
        >
        <span class="flex gap-0.5 text-amber-400">
          {
            googleStars.map(() => (
              <svg
                class="w-4 h-4 sm:w-5 sm:h-5"
                fill="currentColor"
                viewBox="0 0 20 20"
                aria-hidden="true"
              >
                <path d="M10 1l2.6 5.3 5.9.9-4.2 4.1 1 5.8L10 14.8 4.7 17.1l1-5.8L1.5 7.2l5.9-.9z" />
              </svg>
            ))
          }
        </span>
      </div>
    </header>

    <!-- Masonry: CSS columns -->
    <div class="reviews-masonry-columns gap-x-6 space-y-0">
      {
        reviews.map((review) => (
          <article
            class={`review-card break-inside-avoid rounded-2xl bg-white shadow-[0_4px_24px_rgba(12,35,64,0.08)] ring-1 ring-slate-200/80 p-5 sm:p-6 mb-6 ${review.featured ? "featured-card ring-2 ring-[var(--color-navy-soft)]/20" : ""}`}
          >
            <div class="flex items-start justify-between gap-3">
              <div class="flex items-center gap-2">
                <svg
                  class="w-[18px] h-[18px] shrink-0"
                  viewBox="0 0 24 24"
                  aria-hidden="true"
                >
                  <path
                    fill="#4285F4"
                    d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"
                  />
                  <path
                    fill="#34A853"
                    d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"
                  />
                  <path
                    fill="#FBBC05"
                    d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"
                  />
                  <path
                    fill="#EA4335"
                    d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"
                  />
                </svg>
                <span class="flex gap-0.5 text-amber-400">
                  {googleStars.map(() => (
                    <svg
                      class="w-3.5 h-3.5"
                      fill="currentColor"
                      viewBox="0 0 20 20"
                      aria-hidden="true"
                    >
                      <path d="M10 1l2.6 5.3 5.9.9-4.2 4.1 1 5.8L10 14.8 4.7 17.1l1-5.8L1.5 7.2l5.9-.9z" />
                    </svg>
                  ))}
                </span>
              </div>
            </div>
            <p
              class={`mt-4 text-slate-800 leading-relaxed ${review.featured ? "text-base sm:text-lg font-semibold" : "text-sm sm:text-[15px]"}`}
            >
              "{review.quote}"
            </p>
            <div class="mt-4">
              <span class="inline-block rounded-full bg-sky-50 text-sky-800 text-xs font-semibold px-3 py-1 ring-1 ring-sky-100">
                {review.tag}
              </span>
            </div>
            <div class="mt-5 flex items-center gap-3 pt-4 border-t border-slate-100">
              <div
                class={`w-11 h-11 rounded-full bg-gradient-to-br ${review.avatarHue} text-white text-sm font-bold flex items-center justify-center shrink-0 shadow-inner`}
                aria-hidden="true"
              >
                {review.initials}
              </div>
              <div class="min-w-0">
                <div class="font-bold text-[var(--color-navy)] text-sm">
                  {review.name}
                </div>
                <div class="text-xs text-slate-500">{review.location}</div>
              </div>
            </div>
          </article>
        ))
      }
    </div>

    <p class="text-center mt-4">
      <a
        href="https://www.google.com/maps"
        class="inline-flex items-center gap-1 text-sm font-semibold text-[var(--color-navy)] hover:text-[var(--color-accent)] transition-colors"
        target="_blank"
        rel="noopener noreferrer"
      >
        Read all 455+ reviews on Google
        <span aria-hidden="true">→</span>
      </a>
    </p>
  </div>
</section>

<style>
  .reviews-marble {
    background-color: #e8e7e5;
    background-image:
      radial-gradient(
        ellipse 120% 80% at 15% 10%,
        rgba(255, 255, 255, 0.55),
        transparent 50%
      ),
      radial-gradient(
        ellipse 100% 60% at 85% 5%,
        rgba(248, 250, 252, 0.7),
        transparent 45%
      ),
      radial-gradient(
        ellipse 80% 100% at 50% 100%,
        rgba(219, 222, 228, 0.45),
        transparent 55%
      ),
      linear-gradient(
        145deg,
        rgba(235, 233, 230, 0.9) 0%,
        rgba(220, 218, 214, 0.35) 35%,
        rgba(238, 236, 233, 0.6) 55%,
        rgba(228, 226, 222, 0.5) 100%
      ),
      repeating-linear-gradient(
        -8deg,
        transparent,
        transparent 2px,
        rgba(255, 255, 255, 0.035) 2px,
        rgba(255, 255, 255, 0.035) 4px
      );
    background-blend-mode: normal, normal, normal, multiply, normal;
  }

  .reviews-masonry-columns {
    column-fill: balance;
  }

  @media (min-width: 768px) {
    .reviews-masonry-columns {
      column-count: 2;
      column-gap: 1.5rem;
    }
  }

  @media (min-width: 1024px) {
    .reviews-masonry-columns {
      column-count: 3;
      column-gap: 1.5rem;
    }
  }

  .review-card.break-inside-avoid {
    break-inside: avoid;
    page-break-inside: avoid;
  }
</style>
