---
const today = new Date().toLocaleDateString("en-US", {
  weekday: "long",
  month: "long",
  day: "numeric",
  year: "numeric",
});

const colophon = [
  { label: "Equipment", value: "Walk ins · Ice · Reach ins · AC · Heat pumps · Furnaces" },
  { label: "Response", value: "Same day across Mecklenburg, Union, Cabarrus" },
  { label: "Licensed", value: "NC State HVAC License No. 31402" },
  { label: "Hours", value: "Twenty four, seven, three sixty five" },
];
---

<section id="top" class="relative overflow-hidden">
  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 pt-8 sm:pt-12 pb-6">
    <div class="flex flex-wrap items-end justify-between gap-x-4 gap-y-2 font-mono text-[9px] sm:text-[10px] uppercase tracking-[0.24em] sm:tracking-[0.32em] text-[var(--color-ink-muted)] rise" style="animation-delay: 0.05s">
      <span>Vol. XV · No. 31</span>
      <span class="hidden sm:inline">{today}</span>
      <span class="sm:hidden">{today.split(",")[0]}</span>
      <span>Charlotte · NC</span>
      <span class="text-[var(--color-ember)]">~~ Operating ~~</span>
    </div>
    <div class="mt-3 rule-double"></div>
  </div>

  <div class="max-w-[1400px] mx-auto px-4 sm:px-6 lg:px-8 pb-16 lg:pb-20 grid lg:grid-cols-[1.5fr_1fr] gap-10 lg:gap-20">
    <div>
      <p class="font-mono text-[10px] sm:text-[11px] uppercase tracking-[0.28em] sm:tracking-[0.32em] text-[var(--color-ember)] rise" style="animation-delay: 0.15s">
        The Front Page <span class="text-[var(--color-ink-muted)]">/ Issue One</span>
      </p>
      <h1 class="mt-5 sm:mt-6 font-display text-[clamp(2.4rem,9vw,7rem)] leading-[0.94] text-[var(--color-ink)] break-words rise" style="animation-delay: 0.25s; font-variation-settings: 'opsz' 144, 'wght' 900, 'SOFT' 30, 'WONK' 1">
        Reliable
        <span class="italic font-light text-[var(--color-arctic)]" style="font-variation-settings: 'opsz' 144, 'wght' 300">cold</span>
        for the
        <span class="block">Queen City.</span>
      </h1>
      <p class="mt-3 font-display italic font-light text-xl sm:text-2xl md:text-3xl text-[var(--color-ink-soft)] max-w-2xl rise" style="animation-delay: 0.35s; font-variation-settings: 'opsz' 72, 'wght' 300">
        And reliable warmth, every other month of the year.
      </p>

      <p class="mt-7 sm:mt-8 max-w-xl text-[var(--color-ink-soft)] text-base md:text-lg leading-relaxed rise" style="animation-delay: 0.45s">
        QH is a Charlotte crew of refrigeration and HVAC mechanics. We keep
        walk in coolers cold, ice machines flowing, condensers happy in July,
        and furnaces lit when a January cold snap rolls down off the
        Blue Ridge. No high pressure sales, no surprise add ons, no excuses.
      </p>

      <div class="mt-8 sm:mt-10 flex flex-col sm:flex-row sm:flex-wrap sm:items-center gap-3 sm:gap-4 rise" style="animation-delay: 0.55s">
        <a
          href="tel:7045550142"
          class="group inline-flex items-center justify-center sm:justify-start gap-3 bg-[var(--color-ink)] text-[var(--color-paper)] px-5 sm:px-7 py-4 hover:bg-[var(--color-arctic-deep)] transition-colors"
        >
          <span class="font-mono text-[10px] uppercase tracking-[0.32em] opacity-60">Call</span>
          <span class="font-display text-lg font-bold tabular-nums">704·555·0142</span>
          <span class="text-[var(--color-ember-light)] group-hover:translate-x-1 transition-transform">→</span>
        </a>
        <a
          href="#contact"
          class="group inline-flex items-center justify-center sm:justify-start gap-3 border border-[var(--color-ink)] px-5 sm:px-7 py-4 hover:bg-[var(--color-ink)] hover:text-[var(--color-paper)] transition-colors"
        >
          <span class="font-mono text-[11px] uppercase tracking-[0.22em]">Request a Quote</span>
          <span class="group-hover:translate-x-1 transition-transform">→</span>
        </a>
      </div>
    </div>

    <aside class="border-t lg:border-t-0 lg:border-l border-[var(--color-rule)] pt-8 lg:pt-0 lg:pl-10 rise" style="animation-delay: 0.65s">
      <p class="font-mono text-[10px] uppercase tracking-[0.32em] text-[var(--color-ink-muted)]">
        ◇ Colophon
      </p>
      <ul class="mt-5 sm:mt-6 space-y-4 sm:space-y-5">
        {colophon.map((row) => (
          <li>
            <div class="flex items-baseline justify-between gap-4">
              <span class="font-mono text-[10px] uppercase tracking-[0.28em] text-[var(--color-ink-muted)] shrink-0">
                {row.label}
              </span>
              <span class="flex-1 dotted-leader h-2 mb-1"></span>
            </div>
            <p class="mt-1 font-display text-base sm:text-lg leading-snug text-[var(--color-ink)]" style="font-variation-settings: 'opsz' 36, 'wght' 500">
              {row.value}
            </p>
          </li>
        ))}
      </ul>

      <div class="mt-8 sm:mt-10 rule pt-5 sm:pt-6 grid grid-cols-3 gap-2 text-center">
        <div>
          <div class="font-display font-bold text-[var(--color-ink)] tabular-nums text-[clamp(1.5rem,5vw,2rem)]">36°F</div>
          <div class="font-mono text-[8px] sm:text-[9px] uppercase tracking-[0.18em] sm:tracking-[0.22em] text-[var(--color-ink-muted)] mt-1">Walk in</div>
        </div>
        <div class="border-x border-[var(--color-rule)] px-1">
          <div class="font-display font-bold text-[var(--color-arctic)] tabular-nums text-[clamp(1.5rem,5vw,2rem)]">0°F</div>
          <div class="font-mono text-[8px] sm:text-[9px] uppercase tracking-[0.18em] sm:tracking-[0.22em] text-[var(--color-ink-muted)] mt-1">Freezer</div>
        </div>
        <div>
          <div class="font-display font-bold text-[var(--color-ember)] tabular-nums text-[clamp(1.5rem,5vw,2rem)]">68°</div>
          <div class="font-mono text-[8px] sm:text-[9px] uppercase tracking-[0.18em] sm:tracking-[0.22em] text-[var(--color-ink-muted)] mt-1">Home</div>
        </div>
      </div>
    </aside>
  </div>
</section>
